# Copy to .env for local runs:  cp .env.example .env

# --- Models -----------------------------------------------------------------
# Default model is github/openai/gpt-5-mini via GitHub Models. It needs a GitHub
# token with `models: read` and paid/enabled GitHub Models ("custom" tier).
# Falls back to GH_TOKEN / GITHUB_TOKEN if GITHUB_MODELS_TOKEN is unset.
GITHUB_MODELS_TOKEN=

# Override the model per run, e.g.:
#   REVIEW_MODEL=github/openai/gpt-5            # larger/stronger, also paid
#   REVIEW_MODEL=github/openai/gpt-4.1          # free tier, but ~8k token cap
#   REVIEW_MODEL=anthropic/claude-sonnet-4-6    # also set ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=
REVIEW_MODEL=

# --- GitHub (gh CLI) --------------------------------------------------------
# Used by `gh` to read PR diffs and post reviews.
# Locally: a PAT with `repo` scope (or `gh auth login`).
# In CI: the workflow injects ${{ secrets.GITHUB_TOKEN }} automatically.
GH_TOKEN=
