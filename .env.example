# Copy to .env for local runs:  cp .env.example .env
#
# Model provider key. This project uses anthropic/claude-sonnet-4-6.
ANTHROPIC_API_KEY=

# GitHub token used by the `gh` CLI to read PR diffs and post reviews.
# Locally: a PAT with `repo` scope (or `gh auth login`).
# In CI: the workflow injects ${{ secrets.GITHUB_TOKEN }} automatically.
GH_TOKEN=
