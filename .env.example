# Copy to .env for local runs:  cp .env.example .env

# --- Models -----------------------------------------------------------------
# Default model is github/openai/gpt-4.1 via GitHub Models. It needs a GitHub
# token with `models: read`; on a PAID plan its free 8k-token cap lifts to
# production limits (recommended for real reviews). Falls back to
# GH_TOKEN / GITHUB_TOKEN if GITHUB_MODELS_TOKEN is unset.
GITHUB_MODELS_TOKEN=

# Override the model per run, e.g.:
#   REVIEW_MODEL=github/openai/gpt-4o                                # another GitHub model
#   REVIEW_MODEL=anthropic/claude-sonnet-4-6                         # also set ANTHROPIC_API_KEY
#   REVIEW_MODEL=cloudflare-workers-ai/@cf/moonshotai/kimi-k2.6      # also set CLOUDFLARE_* below
# (github/openai/gpt-5* needs the responses API on the GitHub Models provider —
# not wired yet. Reasoning models on cloudflare-workers-ai/* work: pi-ai's
# catalog flags them and the openai-completions adapter sends max_completion_tokens.)
ANTHROPIC_API_KEY=
REVIEW_MODEL=

# --- Cloudflare Workers AI --------------------------------------------------
# For REVIEW_MODEL=cloudflare-workers-ai/@cf/...
# The provider is built into Flue (via pi-ai's catalog); no app.ts registration
# needed. Kimi K2.6 (`@cf/moonshotai/kimi-k2.6`) gives a 262k context window,
# vision, tool calling, and reasoning at $0.95/$4.00 per M input/output tokens.
# CLOUDFLARE_API_KEY must be an API token with the "Workers AI" → Read scope.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_KEY=

# --- GitHub (gh CLI) --------------------------------------------------------
# Used by `gh` to read PR diffs and post reviews.
# Locally: a PAT with `repo` scope (or `gh auth login`).
# In CI: the workflow injects ${{ secrets.GITHUB_TOKEN }} automatically.
GH_TOKEN=

# --- Docs MCP ---------------------------------------------------------------
# The reviewer connects the Flipt docs MCP (no auth) to ground reviews in the
# docs — on by default (https://docs.flipt.io/mcp). Leave this unset to use the
# default; set it to another URL to point elsewhere, or to empty to disable.
# REVIEW_DOCS_MCP_URL=
